# Server
PORT=4010

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=KnowledgeBase
MONGODB_DATABASE=knowledge_base

# Voyage AI via the MongoDB-managed gateway (recommended).
#
# Create a "Model API Key" in
#   Atlas → Organization → Access Manager → Model API Keys
# The key is prefixed `al-...`.
#
# If you'd rather call Voyage directly, set:
#   VOYAGE_BASE_URL=https://api.voyageai.com/v1
# and use a `pa-...` key from https://dash.voyageai.com.
VOYAGE_BASE_URL=https://ai.mongodb.com/v1
VOYAGE_API_KEY=al-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# Atlas Search index names (created via scripts/create-indexes.js)
ATLAS_SEARCH_INDEX=articles_search
ATLAS_VECTOR_INDEX=chunks_vector

# CORS
#   "*"                              → allow any origin (default)
#   "localhost"                      → allow any http://localhost:PORT (handy in dev)
#   "https://app.example.com,https://x"  → comma-separated allow-list
CORS_ORIGIN=localhost
