# Server
PORT=8080

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=KnowledgeBase
MONGODB_DATABASE=knowledge_base

# Voyage AI
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# Atlas Search index names (created via scripts/create-indexes.js)
ATLAS_SEARCH_INDEX=articles_search
ATLAS_VECTOR_INDEX=chunks_vector

# CORS
CORS_ORIGIN=http://localhost:3000
